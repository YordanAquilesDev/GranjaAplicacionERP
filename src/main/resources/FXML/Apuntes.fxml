<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml/1" fx:controller="presentacion.controller.ApuntesController">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <!-- Contenedor que simula la hoja de papel -->
    <StackPane style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
        <!-- El lienzo para "pincelear" -->
        <Canvas fx:id="canvasApuntes" width="600" height="400" 
                onMousePressed="#empezarTrazo" 
                onMouseDragged="#pincelear"/>
    </StackPane>

    <!-- Botones de acción -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Borrar Todo" onAction="#limpiarLienzo"/>
        <Button text="Guardar Dibujo" onAction="#guardarLienzo" style="-fx-background-color: #28a745; -fx-text-fill: white;"/>
    </HBox>
</VBox>