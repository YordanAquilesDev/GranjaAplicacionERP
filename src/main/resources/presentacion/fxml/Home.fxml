<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.Region?>

<BorderPane stylesheets="@../css/Home.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="presentacion.controller.HomeController">

    <!-- MENÚ LATERAL IZQUIERDO (Fijo) -->
    <left>
        <VBox styleClass="sidebar" prefWidth="260.0">
            <children>
                <!-- Sección de Título / Logo del Dashboard opcional -->
                <VBox styleClass="brand-container" alignment="CENTER_LEFT">
                    <children>
                        <javafx.scene.control.Label text="TERRACROP" styleClass="brand-title"/>
                        <javafx.scene.control.Label text="Panel de Administración" styleClass="brand-subtitle"/>
                    </children>
                </VBox>

                <!-- Botones del Menú Principal -->
                <Button fx:id="btnHome" text="🏠  Panel Principal" onAction="#navegarHome" styleClass="menu-button"/>
                <Button fx:id="btnAnimales" text="🐖  Animales" onAction="#navegarAnimales" styleClass="menu-button"/>
                <Button fx:id="btnLote" text="📦  Lotes" onAction="#navegarLotes" styleClass="menu-button"/>
                <Button fx:id="btnPedidos" text="📋  Pedidos" onAction="#navegarPedidos" styleClass="menu-button"/>
                <Button fx:id="btnVenta" text="💰  Ventas" onAction="#navegarVentas" styleClass="menu-button"/>
                <Button fx:id="btnConsumo" text="🥣  Consumo Lote" onAction="#navegarConsumoLote" styleClass="menu-button"/>
                <Button fx:id="btnStock" text="🌾  Stock / Almacén" onAction="#navegarStock" styleClass="menu-button"/>
                <Button fx:id="btnMovim" text="🔄  Movimientos" onAction="#navegarMovimientos" styleClass="menu-button"/>
                <Button fx:id="btnCompra" text="🛒  Compras" onAction="#navegarCompras" styleClass="menu-button"/>

                <!-- Empujador dinámico vertical -->
                <Region VBox.vgrow="ALWAYS" />

                <!-- Botón Salir en la zona inferior -->
                <Button fx:id="btnSalir" text="🚪  Salir del Sistema" onAction="#Salir" styleClass="menu-button-exit"/>
            </children>
        </VBox>
    </left>
    <!-- CONTENEDOR CENTRAL DINÁMICO (Aquí se inyecta el Dashboard o cualquier otra pantalla) -->
    <center>
        <StackPane fx:id="contenedorPrincipal" styleClass="main-content-area" />
    </center>
</BorderPane>