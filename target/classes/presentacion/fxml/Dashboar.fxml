<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>

<ScrollPane fx:id="scrollPrincipal" fitToWidth="true" styleClass="dashboard-scroll"
            stylesheets="@../css/Dashboard.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="presentacion.controller.DashboardController">
    <content>
        <VBox spacing="24.0" styleClass="dashboard-container">
            <padding>
                <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
            </padding>

            <!-- Encabezado Principal -->
            <VBox spacing="4.0">
                <children>
                    <Label text="Panel Principal - Gestión de la Granja" styleClass="dashboard-title"/>
                    <Label text="Resumen operativo, sanitario y comercial del sector pecuario." styleClass="dashboard-subtitle"/>
                </children>
            </VBox>

            <!-- Fila 1: KPIs Principales (Operaciones y Ventas) -->
            <GridPane hgap="15.0" vgap="15.0">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.3"/>
                    <ColumnConstraints percentWidth="33.3"/>
                    <ColumnConstraints percentWidth="33.3"/>
                </columnConstraints>
                <children>
                    <VBox styleClass="kpi-card, kpi-card-interactive" GridPane.columnIndex="0" onMouseClicked="#navegarAnimales">
                        <children>
                            <Label  text="TOTAL ANIMALES" styleClass="kpi-header"/>
                            <Label fx:id="txtTotalAnimales" text="1,240" styleClass="kpi-value"/>
                            <Label text="Ver listado y registro diario →" styleClass="kpi-subtext"/>
                        </children>
                    </VBox>

                    <VBox styleClass="kpi-card, kpi-card-accent, kpi-card-interactive" GridPane.columnIndex="1" onMouseClicked="#navegarLotes">
                        <children>
                            <Label text="LOTES MONITOREADOS" styleClass="kpi-header"/>
                            <Label fx:id="txtTotalLotes"   text="18 Lotes" styleClass="kpi-value"/>
                            <Label text="Ver distribución por sectores →" styleClass="kpi-subtext"/>
                        </children>
                    </VBox>

                    <VBox styleClass="kpi-card, kpi-card-interactive" GridPane.columnIndex="2" onMouseClicked="#navegarPedidos">
                        <children>
                            <Label text="PEDIDOS POR ENTREGAR" styleClass="kpi-header"/>
                            <Label text="7 Pedidos" styleClass="kpi-value"/>
                            <Label text="Gestionar despachos de hoy →" styleClass="kpi-subtext"/>
                        </children>
                    </VBox>
                </children>
            </GridPane>

            <!-- Fila 2: Alertas Críticas y Eficiencia -->
            <GridPane hgap="15.0" vgap="15.0">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.3"/>
                    <ColumnConstraints percentWidth="33.3"/>
                    <ColumnConstraints percentWidth="33.3"/>
                </columnConstraints>
                <children>
                    <VBox styleClass="kpi-card, kpi-card-warning, kpi-card-interactive" GridPane.columnIndex="0" onMouseClicked="#navegarSanidad">
                        <children>
                            <Label text="ALERTAS SANITARIAS" styleClass="kpi-header"/>
                            <Label text="0.8% Mort." styleClass="kpi-value"/>
                            <Label text="2 casos en aislamiento temporal →" styleClass="kpi-subtext-warning"/>
                        </children>
                    </VBox>

                    <VBox styleClass="kpi-card, kpi-card-interactive" GridPane.columnIndex="1" onMouseClicked="#navegarEficiencia">
                        <children>
                            <Label text="IND. CONVERSIÓN (ICA)" styleClass="kpi-header"/>
                            <Label text="2.45 kg" styleClass="kpi-value"/>
                            <Label text="Promedio óptimo del mes actual →" styleClass="kpi-subtext"/>
                        </children>
                    </VBox>

                    <VBox styleClass="kpi-card, kpi-card-info, kpi-card-interactive" GridPane.columnIndex="2" onMouseClicked="#navegarSensores">
                        <children>
                            <Label text="AMBIENTE GALPONES" styleClass="kpi-header"/>
                            <Label text="24.5 °C" styleClass="kpi-value"/>
                            <Label text="Humedad: 62% - Confort Estable →" styleClass="kpi-subtext-info"/>
                        </children>
                    </VBox>
                </children>
            </GridPane>

            <!-- NUEVA FILA 3: Estado del Negocio y Rentabilidad (%) -->
            <GridPane hgap="15.0" vgap="15.0">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.3"/>
                    <ColumnConstraints percentWidth="33.3"/>
                    <ColumnConstraints percentWidth="33.3"/>
                </columnConstraints>
                <children>
                    <!-- Margen de Rentabilidad Actual -->
                    <VBox styleClass="kpi-card, kpi-card-success, kpi-card-interactive" GridPane.columnIndex="0" onMouseClicked="#navegarFinanzas">
                        <children>
                            <Label text="MARGEN DE RENTABILIDAD" styleClass="kpi-header"/>
                            <Label text="28.4 %" styleClass="kpi-value-success"/>
                            <Label text="↑ +3.2% respecto al ciclo anterior" styleClass="kpi-subtext-success"/>
                        </children>
                    </VBox>

                    <!-- Utilidad Neta Proyectada -->
                    <VBox styleClass="kpi-card, kpi-card-interactive" GridPane.columnIndex="1" onMouseClicked="#navegarFinanzas">
                        <children>
                            <Label text="UTILIDAD NETA ESTIMADA" styleClass="kpi-header"/>
                            <Label text="S/. 18,420" styleClass="kpi-value"/>
                            <Label text="Proyección basada en lotes listos" styleClass="kpi-subtext"/>
                        </children>
                    </VBox>

                    <!-- Costo de Alimento vs Inversión Total -->
                    <VBox styleClass="kpi-card, kpi-card-interactive" GridPane.columnIndex="2" onMouseClicked="#navegarCompras">
                        <children>
                            <Label text="IMPACTO COSTO ALIMENTO" styleClass="kpi-header"/>
                            <Label text="64.2% del Gasto" styleClass="kpi-value"/>
                            <Label text="Principal componente de egresos" styleClass="kpi-subtext"/>
                        </children>
                    </VBox>
                </children>
            </GridPane>

            <!-- Fila 4: Gráfico Financiero (Ventas vs Compras) -->
            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                <children>
                    <VBox styleClass="chart-container, kpi-card-interactive" HBox.hgrow="ALWAYS" prefHeight="320.0" onMouseClicked="#navegarVentas">
                        <children>
                            <Label text="Flujo Financiero Semanal: Ventas de Ganadería vs Compras de Insumos" styleClass="section-inner-title"/>

                            <BarChart fx:id="chartBalance" legendSide="TOP" verticalGridLinesVisible="false" mouseTransparent="true">
                                <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                <yAxis><NumberAxis side="LEFT" /></yAxis>
                            </BarChart>

                        </children>
                    </VBox>
                </children>
            </HBox>

            <!-- NUEVA FILA 5: Monitoreo Biológico -->
            <!-- FILA 5: Monitoreo Biológico -->
            <VBox styleClass="info-block" spacing="12.0">
                <children>
                    <Label text="📊 Control Biológico y Eficiencia Operativa por Lote Activo" styleClass="section-inner-title"/>
                    <!-- CORREGIDO: Se quitaron las propiedades vbarPolicy y hbarPolicy -->
                    <TableView fx:id="tblRendimientoLotes" prefHeight="180.0" styleClass="tabla-dashboard">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colLoteNombre" text="Código Lote" prefWidth="120.0"/>
                            <TableColumn fx:id="colLotePoblacion" text="Pob. Inicial" prefWidth="100.0"/>
                            <TableColumn fx:id="colLoteBajas" text="Bajas (Muertes)" prefWidth="120.0"/>
                            <TableColumn fx:id="colLoteMortalidad" text="Tasa Mortalidad (%)" prefWidth="140.0"/>
                            <TableColumn fx:id="colLoteConsumo" text="Consumo Promedio" prefWidth="150.0"/>
                            <TableColumn fx:id="colLoteSanidad" text="Estado Sanitario / Vacunación" prefWidth="180.0"/>
                        </columns>
                    </TableView>
                </children>
            </VBox>

            <!-- FILA 6: Planificación de Campañas -->
            <VBox styleClass="info-block" spacing="12.0">
                <children>
                    <Label text="🚀 Cronograma de Salida al Mercado (Maduración de Campaña)" styleClass="section-inner-title"/>
                    <!-- CORREGIDO: Se quitaron las propiedades vbarPolicy y hbarPolicy -->
                    <TableView fx:id="tblLotesPróximos" prefHeight="180.0" styleClass="tabla-dashboard">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colProgresoLote" text="Lote Destino" />
                            <TableColumn fx:id="colProgresoTipo" text="Especie / Destino Comercial" />
                            <TableColumn fx:id="colProgresoDias" text="Días en Campaña" />
                            <TableColumn fx:id="colProgresoFecha" text="Fecha Estimada de Salida" />
                            <TableColumn fx:id="colProgresoEstado" text="Estado de Crecimiento" />
                        </columns>
                    </TableView>
                </children>
            </VBox>
            <!-- Fila 7: Bloques de Almacén y Movimientos Simples -->
            <GridPane hgap="20.0">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50.0"/>
                    <ColumnConstraints percentWidth="50.0"/>
                </columnConstraints>
                <children>
                    <VBox styleClass="info-block, kpi-card-interactive" GridPane.columnIndex="0" onMouseClicked="#navegarStock">
                        <children>
                            <Label text="Estado de Almacén (Gestionar Stock →)" styleClass="section-inner-title"/>
                            <Label fx:id="txtAlimento1"   text="• Alimento Balanceado: 450 kg (Crítico)" styleClass="info-item-danger"/>
                            <Label fx:id="txtAlimento2"  text="• Medicamentos &amp; Vacunas: Stock Estable" styleClass="info-item"/>
                            <Label fx:id="txtAlimento3"  text="• Suministros generales: 85% de capacidad" styleClass="info-item"/>
                        </children>
                    </VBox>

                    <VBox styleClass="info-block, kpi-card-interactive" GridPane.columnIndex="1" onMouseClicked="#navegarMovimientos">
                        <children>
                            <Label  text="Últimos Movimientos (Kardex Completo →)" styleClass="section-inner-title"/>
                            <Label fx:id="txtMovimiento1" text="• Ingreso: Lote 04-B (Porcinos) - Hace 2 horas" styleClass="info-item"/>
                            <Label fx:id="txtMovimiento2" text="• Compra: Suministros Veterinaria Norte - Ayer" styleClass="info-item"/>
                            <Label fx:id="txtMovimiento3" text="• Actualización: Registro de peso diario completado" styleClass="info-item"/>
                        </children>
                    </VBox>
                </children>
            </GridPane>
        </VBox>
    </content>
</ScrollPane>