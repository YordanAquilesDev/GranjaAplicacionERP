<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="presentacion.controladores.DashboardController" HBox.hgrow="ALWAYS">
    <children>

        <VBox prefWidth="480.0" styleClass="content-area" HBox.hgrow="ALWAYS">
            <children>
                <Label styleClass="main-title" text="Dashboard" />

                <VBox styleClass="chart-card">
                    <children>
                        <HBox>
                            <children>
                                <Label styleClass="card-title" text="Activity" />
                                <Pane HBox.hgrow="ALWAYS" />
                                <Label styleClass="card-subtitle" text="Year / Month" />
                            </children>
                        </HBox>
                        <LineChart fx:id="graficoBalance" prefHeight="400.0" prefWidth="850.0">
                            <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                            <yAxis><NumberAxis side="LEFT" /></yAxis>
                        </LineChart>
                    </children>
                </VBox>

                <VBox styleClass="chart-card">
                    <children>
                        <Label styleClass="card-title" text="Performance Statistics" />
                        <BarChart prefHeight="160.0">
                            <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                            <yAxis><NumberAxis side="LEFT" /></yAxis>
                        </BarChart>
                    </children>
                </VBox>
            </children>
        </VBox>

        <VBox prefWidth="250.0" styleClass="right-sidebar">
            <children>
                <VBox prefHeight="220.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-title" text="Calendar / Tasks" />
                    </children>
                </VBox>

                <VBox prefHeight="220.0" styleClass="info-card">
                    <children>
                        <Label styleClass="card-title" text="Expenses Summary" />
                    </children>
                </VBox>
            </children>
        </VBox>

    </children>
</HBox>