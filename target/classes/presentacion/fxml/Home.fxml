                    </graphic>
                </Button>

                <!-- Compra-->
                <Button fx:id="btnCompra" onAction="#navegarCompras" text="Compras" maxWidth="1.7976931348623157E308" styleClass="menu-button">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../image/icon/carro-de-la-compra.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- animales-->
                <Button fx:id="btnCompra" onAction="#navegarAnimales" text="Animales" maxWidth="1.7976931348623157E308" styleClass="menu-button">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../image/icon/editar.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- Venta-->
                <Button fx:id="btnVenta" onAction="#navegarVentas" text="Ventas" maxWidth="1.7976931348623157E308" styleClass="menu-button">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../image/icon/dinero.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>


                <!-- Clientes-->
                <Button fx:id="btnClientes" onAction="#navegarClientes" text="Clientes" maxWidth="1.7976931348623157E308" styleClass="menu-button">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../image/icon/usuarios.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- Proveedor-->
                <Button fx:id="btnProveedor" onAction="#navegarProveedores" text="Proveedores" maxWidth="1.7976931348623157E308" styleClass="menu-button">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../image/icon/avatar.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- Carga Datos-->
                <Button fx:id="btnCarga" onAction="#navegarCargaDatos" text="Carga Datos" maxWidth="1.7976931348623157E308" styleClass="menu-button">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../image/icon/subir.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- Stock-->
                <Button fx:id="btnStock" onAction="#navegarStock" text="Almacen" maxWidth="1.7976931348623157E308" styleClass="menu-button">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../image/icon/biblioteca.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- Salir-->
                <Button fx:id="btnSalir" onAction="#Salir" text="Salir" maxWidth="1.7976931348623157E308" styleClass="menu-button">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../image/icon/cerrar-sesion.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>


 <!--               <Pane VBox.vgrow="ALWAYS" />

                <Button fx:id="btnLogout" text="Logout" maxWidth="1.7976931348623157E308" styleClass="logout-button" />
            </children>
        </VBox>

