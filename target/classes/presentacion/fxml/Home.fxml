<HBox prefHeight="650.0" prefWidth="950.0" spacing="10.0"
      stylesheets="@../css/Home.css"
      styleClass="main-container"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="presentacion.controladores.HomeController">

    <children>
        <VBox prefWidth="220.0" styleClass="sidebar">
            <children>
                <VBox styleClass="profile-container">
                    <children>
                        <ImageView fitHeight="70.0" fitWidth="70.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../image/granja.png" />
                            </image>
                        </ImageView>
                    </children>
                </VBox>

                <!-- Home -->
                <Button fx:id="btnHome" onAction="#navegarHome" text="Home" maxWidth="1.7976931348623157E308" styleClass="menu-button">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../image/icon/hogar.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- Pedidos -->
                <Button fx:id="btnPedidos" onAction="#navegarPedidos" text="Pedidos" maxWidth="1.7976931348623157E308" styleClass="menu-button-active">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../image/icon/auriculares.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>


                <!-- Lote Animal -->
                <Button fx:id="btnLote" onAction="#navegarLotes" text="Lotes Animales" maxWidth="1.7976931348623157E308" styleClass="menu-button">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../image/icon/capas.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- Granja -->
                <Button fx:id="btnGranja" onAction="#navegarGranja" text="Granja" maxWidth="1.7976931348623157E308" styleClass="menu-button">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../image/icon/ojo.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- Movimientos -->
                <Button fx:id="btnMovim" onAction="#navegarMovimientos" text="Movimientos" maxWidth="1.7976931348623157E308" styleClass="menu-button">
                    <graphic>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
