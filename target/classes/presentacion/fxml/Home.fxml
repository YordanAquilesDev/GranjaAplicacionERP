                            <yAxis><NumberAxis side="LEFT" /></yAxis>
                        </BarChart>
                    </children>
                </VBox>
            </children>
        </VBox>

        <VBox prefWidth="250.0" styleClass="right-sidebar">
            <children>
                <VBox styleClass="info-card" prefHeight="220.0">
                    <children>
                        <Label text="Calendar / Tasks" styleClass="card-title" />
                    </children>
                </VBox>

                <VBox styleClass="info-card" prefHeight="220.0">
                    <children>
                        <Label text="Expenses Summary" styleClass="card-title" />
                    </children>
                </VBox>-->
