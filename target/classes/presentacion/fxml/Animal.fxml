<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="650.0" prefWidth="950.0" spacing="10.0"
      stylesheets="@../css/Animal.css"
      styleClass="main-container"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="presentacion.controller.AnimalController">

   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label text="Gestión de Animales (CRUD Hexagonal)" styleClass="titulo-principal">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>

      <BorderPane VBox.vgrow="ALWAYS">
         <left>
            <VBox prefWidth="300.0" spacing="15.0" BorderPane.alignment="CENTER">
               <padding>
                  <Insets right="20.0" top="10.0" />
               </padding>
               <children>
                  <Label text="Datos del Animal" styleClass="subtitulo-seccion" />

                  <GridPane vgap="10.0" hgap="10.0">
                     <children>
                        <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                        <TextField fx:id="txtId" editable="false" promptText="Autogenerado" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="form-input"/>

                        <Label text="Especie:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                        <TextField fx:id="txtEspecie" promptText="Ej. Canino" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="form-input"/>

                        <Label text="Raza:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                        <TextField fx:id="txtRaza" promptText="Ej. Pastor Alemán" GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="form-input"/>
                     </children>
                  </GridPane>

                  <HBox spacing="10.0">
                     <children>
                        <Button fx:id="btnGuardar" id="boton-guardar" mnemonicParsing="false" onAction="#handleGuardar" text="Guardar" prefWidth="90.0"/>
                        <Button fx:id="btnLimpiar" id="boton-limpiar" mnemonicParsing="false" onAction="#handleLimpiar" text="Limpiar" prefWidth="90.0"/>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </left>

         <center>
            <VBox spacing="10.0" BorderPane.alignment="CENTER">
               <children>
                  <TableView fx:id="tblAnimales" onMouseClicked="#handleSeleccionarFila" VBox.vgrow="ALWAYS" styleClass="tabla-moderna">
                     <columns>
                        <TableColumn fx:id="colId" prefWidth="100.0" text="ID" />
                        <TableColumn fx:id="colEspecie" prefWidth="250.0" text="Especie" />
                        <TableColumn fx:id="colRaza" prefWidth="250.0" text="Raza" />
                     </columns>
                  </TableView>
               </children>
            </VBox>
         </center>
      </BorderPane>
   </children>
</VBox>