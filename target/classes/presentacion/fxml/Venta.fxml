<?xml version="1.0" encoding="UTF-8"?>

<!--
    Módulo de Facturación y Ventas Mayoristas
    Estructura optimizada para la relación Maestro-Detalle
-->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="750.0" prefWidth="1250.0" spacing="20.0"
      stylesheets="@../css/Venta.css"
      styleClass="main-container"
      xmlns="http://javafx.com/javafx/13"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="presentacion.controller.VentaController">

    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>

    <!-- Encabezado Comercial -->
    <VBox spacing="4.0">
        <children>
            <Label text="Módulo: Ventas Mayoristas" styleClass="titulo-principal" />
            <Label text="Facturación, gestión de comprobantes y salidas comerciales de lotes terminados." styleClass="subtitulo-principal" />
        </children>
    </VBox>

    <BorderPane VBox.vgrow="ALWAYS">
        <!-- Sección Izquierda: Datos de la Venta y Añadir Productos -->
        <left>
            <VBox prefWidth="380.0" spacing="16.0" BorderPane.alignment="CENTER">
                <children>

                    <!-- Tarjeta 1: Datos de Cabecera (Venta Maestro) -->
                    <VBox spacing="12.0" styleClass="card-panel">
                        <padding>
                            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <children>
                            <Label text="Datos de Facturación" styleClass="subtitulo-seccion" />
                            <GridPane vgap="10.0" hgap="10.0">
                                <columnConstraints>
                                    <ColumnConstraints prefWidth="90.0" minWidth="90.0"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>
                                <children>
                                    <Label text="ID Venta:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                                    <TextField fx:id="txtIdVenta" editable="false" promptText="Autogenerado" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="form-input-disabled"/>

                                    <Label text="Cliente:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                                    <ComboBox fx:id="cmbCliente" promptText="Seleccionar cliente" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="form-combo" maxWidth="1.7976931348623157E308"/>

                                    <Label text="Fecha:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                                    <DatePicker fx:id="dpFecha" promptText="dd/mm/aaaa" GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="form-datepicker" maxWidth="1.7976931348623157E308"/>
                                </children>
                            </GridPane>
                        </children>
                    </VBox>

                    <!-- Tarjeta 2: Agregar Ítem al Detalle -->
                    <VBox spacing="12.0" styleClass="card-panel" VBox.vgrow="ALWAYS">
                        <padding>
                            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <children>
                            <Label text="Agregar Producto / Lote" styleClass="subtitulo-seccion" />
                            <GridPane vgap="10.0" hgap="10.0">
                                <columnConstraints>
                                    <ColumnConstraints prefWidth="90.0" minWidth="90.0"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>
                                <children>
                                    <Label text="Producto:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                                    <ComboBox fx:id="cmbProducto" promptText="Seleccionar ítem" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="form-combo" maxWidth="1.7976931348623157E308"/>

                                    <Label text="Cantidad:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                                    <TextField fx:id="txtCantidad" promptText="Ej. 100" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="form-input"/>

                                    <Label text="Precio Unit:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                                    <TextField fx:id="txtPrecioUnitario" promptText="S/. 0.00" GridPane.columnIndex="1" GridPane.rowIndex="2" styleClass="form-input"/>
                                </children>
                            </GridPane>

                            <!-- Botón intermedio para cargar al carrito -->
                            <Button fx:id="btnAgregarItem" styleClass="btn-secundario" mnemonicParsing="false" onAction="#handleAgregarItem" text="Añadir al Detalle" maxWidth="1.7976931348623157E308">
                                <VBox.margin>
                                    <Insets top="8.0" />
                                </VBox.margin>
                            </Button>
                        </children>
                    </VBox>
                </children>
                <BorderPane.margin>
                    <Insets right="20.0" />
                </BorderPane.margin>
            </VBox>
        </left>

        <!-- Sección Derecha: Tabla de Detalles del Carrito y Confirmación de Transacción -->
        <center>
            <VBox spacing="16.0" BorderPane.alignment="CENTER" styleClass="card-panel-table">
                <children>
                    <Label text="Detalle de la Venta Actual" styleClass="subtitulo-seccion-tabla" />

                    <!-- Tabla Autoajustable para DetalleVenta -->
                    <TableView fx:id="tblDetalleVenta" VBox.vgrow="ALWAYS" styleClass="tabla-moderna">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colProducto" prefWidth="220.0" text="Producto / Concepto" />
                            <TableColumn fx:id="colCantidad" prefWidth="100.0" text="Cantidad" />
                            <TableColumn fx:id="colPrecio" prefWidth="120.0" text="Precio Unitario" />
                            <TableColumn fx:id="colSubtotal" prefWidth="140.0" text="Subtotal" />
                        </columns>
                    </TableView>

                    <!-- Barra Inferior: Totales y Acciones Principales de Registro -->
                    <HBox alignment="CENTER_RIGHT" spacing="20.0" styleClass="container-totales">
                        <padding>
                            <Insets top="12.0" bottom="4.0" left="12.0" right="12.0"/>
                        </padding>
                        <children>
                            <Button fx:id="btnRemoverItem" styleClass="btn-remover" mnemonicParsing="false" onAction="#handleRemoverItem" text="Quitar Línea" />
                            <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS" spacing="10.0">
                                <children>
                                    <Label text="TOTAL A FACTURAR:" styleClass="label-total-vta" />
                                    <Label fx:id="lblTotal" text="S/. 0.00" styleClass="monto-total-vta" />
                                </children>
                            </HBox>
                            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                                <children>
                                    <Button fx:id="btnCancelar" styleClass="btn-crud, btn-limpiar" mnemonicParsing="false" onAction="#handleLimpiarTodo" text="Cancelar" />
                                    <Button fx:id="btnGuardarVenta" styleClass="btn-crud, btn-guardar" mnemonicParsing="false" onAction="#handleGuardarVenta" text="Procesar Venta" />
                                </children>
                            </HBox>
                        </children>
                    </HBox>
                </children>
            </VBox>
        </center>
    </BorderPane>
</VBox>